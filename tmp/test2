cache table cell_rank_top3
select
    cellkey,
    regionid,
    x_offset,
    y_offset,
    cell_grid_mr_count,
    cell_rank
from
    (
        select
            cellkey,
            regionid,
            x_offset,
            y_offset,
            cell_grid_mr_count,
            row_number() over(
                partition by regionid,
                x_offset,
                y_offset
                order by
                    cell_grid_mr_count desc
            ) as cell_rank
        from
            (
                select
                    cellkey,
                    regionid,
                    x_offset,
                    y_offset,
                    sum(validlonlat_totalmrcount) cell_grid_mr_count
                from
                    test_db.aggr_lte_coverage_base_refactor_d
                where
                    p_provincecode ='${p_provincecode}'
                    and p_date = '${p_date}'
                group by
                    cellkey,
                    regionid,
                    x_offset,
                    y_offset
            )
    )
where
    cell_rank <= 3;

cache table cell_rank_top3_1
select
    cellkey,
    regionid,
    x_offset,
    y_offset,
    cell_grid_mr_count,
    cell_rank
from
    cell_rank_top3
where
    cell_rank = 1;

cache table cell_rank_top3_2
