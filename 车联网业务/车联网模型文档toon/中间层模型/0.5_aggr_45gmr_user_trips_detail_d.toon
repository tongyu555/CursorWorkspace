  cellid, int, 基站cellid, A, cellid, 直取, null, null, 维度, 无, 无
  rattype, string, 网络类型（4G、5G）, A, rattype, 直取, null, null, 维度, 无, 无
  p_region, int, 厂商分区, A, p_region, 直取, null, null, 维度, 无, 无
  mr_cnt, int, mr 个数, "A|B", null, route_point_id聚合后统计MR个数, null, null, 指标, 无, >=0
