  route_point_lat, double, 道路端点维度, "A|B", null, 道路端点纬度, null, null, 维度, 无, >=0
  rsrp, float, rsrp, "A|B", null, route_point_id聚合后取MR的rsrp平均值, null, null, 指标, 无, 无
  rsrq, float, rsrq, "A|B", null, route_point_id聚合后取MR的rsrq平均值, null, null, 指标, 无, 无
