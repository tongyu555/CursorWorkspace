  max_endtime, string, 最大结束时间(时间戳), "A|A1", null, max(max_endtime), null, null, 指标, 无, >0
  rsrp_avg, double, 平均rsrp, "A|A1", null, sum(totalrsrp)/sum(rsrpcount), null, null, 指标, 无, "[-140,-43]"
  rsrp_cnt, bigint, rsrp总采样点数, "A|A1", null, sum(rsrpcount), null, null, 指标, 无, >0
