theme_domain: null
table_name: fact_5gdpi_n1n2_e2e_telecom_h
table_name_chinese: SA控制面N1N2接口事实表
data_frequency: hour
primary_key: 数据描述
source_table_name[3]{源表英文名, 源表中文名, 别名}:
  ods_5gdpi_n1n2_e2e_telecom_5min, 5G N1N2贴源详单表, A
  cfg_s1mme_cause code_list, n1n2定界定位编码表, C
  fact_nr_cm_projdata, 5G电联工参, B
fields[325]{PDM字段英文名, PDM字段类型, PDM字段中文名（说明）, 源表名, 源字段英文名, 算法加工逻辑, 关联与过滤条件, 备注, 字段属性, 单位, 取值范围}:
  interface, int, "必填字段。接口类型：\n1：S1-U\n2：S1-MME\n3：S6a\n4：S11\n6：S5-C\n14：L2TP\n16：Gm信令面\n28：Gm接口VoLTE会话xDR（Gm Session xDR）\n29：Gm接口VoLTE切片xDR（Gm Slice xDR）\n31：S1-U接口VoLTE切片xDR（S1-U Slice xDR）\n35：Radius\n50：N1N2\n51：N4\n52：N5\n53：N7\n54：N8\n55：N10\n56：N11\n57：N12\n58：N14\n59：N15\n66：N16\n60：N22\n61：N26\n62：N40\n63：N13\n100：User Plane（5G SA指N3接口）\n", null, null, null, null, null, null, null, null
  xdr_id, string, 必填字段。采集解析服务器内唯一的xDR编号。一个信令流程或业务传输过程生成一个xDR ID。对于信令面xDR，一个xDR ID可能对应同一信令流程中的多条原始消息记录。, null, null, null, null, null, null, null, null
  supi, string, 永久用户标识。4G 填写用户IMSI。, null, null, null, null, null, null, null, null
  pei, string, 永久设备标识。4G填写IMEI/IMEISV。保持信令抽取的原样，无需进行IMEI和IMEISV间的转化。, null, null, null, null, null, null, null, null
  msisdn, string, 用户号码。, null, null, null, null, null, null, null, null
  rat, int, RAT类型：取各接口码流中携带的值。如果接入类型为5G NR，将RAT值改写为10。, null, null, null, null, null, null, null, null
  home_province, string, 用户的归属地省份，枚举定义参见附录G。对国际漫入用户时，该字段填写用户归属运营商PLMN。, null, null, null, null, null, null, null, null
  procedure_type, int, " 流程类型编码，具体取值如下：\n0： Registration\n1： De-registration\n2： Service Request\n3： UE Configuration Update\n4： SMS\n30： PDU Session Establishment\n31： PDU Session Modification\n32： PDU Session Release\n60： N2 HO Out\n61： N2 HO In\n62： N2 HO Cancel\n63： Xn HO\n64： UE Context Release\n73： UE Capability Info Indication\n74： UE Radio Capability Check\n75： Trace Start\n76： Deactivate Trace\n77： Cell traffic Trace\n78： NG Reset\n79： Error indication\n80： NG Setup\n81： RAN Configuration Update\n82： AMF Configuration Update\n83： Overload Start\n84： Overload Stop", null, null, null, null, null, null, null, null
  procedure_start_time, bigint, "业务流程开始时间，UTC时间，从1970/1/1 00:00:00开始到当前的毫秒数。", null, null, null, null, null, null, null, null
  procedure_end_time, bigint, "业务流程结束时间，UTC时间，从1970/1/1 00:00:00开始到当前的毫秒数。", null, null, null, null, null, null, null, null
  procedure_status, int, "流程状态\n1：成功；\n2：失败；\n3：超时\n", null, null, null, null, null, null, null, null
  request_cause_type, int, "标识流程请求消息中cause字段所对应的Cause Group。\n失败原因类型，对于5G NAS流程：\n1：5GMM\n2：5GSM\n对于NGAP流程：\n1：Radio Network Layer\n2：Transport Layer\n3：NAS\n4：Protocol\n5：Misc\n对于SMS流程：\n1：CP Cause\n2：RP Cause", null, null, null, null, null, null, null, null
  request_cause, int, "流程的请求消息中所包含的Cause值：\n针对De-registration流程，填写De-registration Request消息中的Cause值；\n针对PDU Session Modification流程，填写PDU Session Modification Request/PDU Session Modification Command消息中的Cause值；\n针对PDU Session Release流程，填写PDU SessionRelease Request/PDU Session Release Command消息中的Cause值；\n针对N2 Handover Out流程，填写HANDOVER REQUIRED消息中的Cause值；\n针对N2 Handover In流程，填写HANDOVER REQUEST消息中的Cause值；\n针对N2 Handover Cancel流程，填写HANDOVER CANCEL消息中的Cause值；\n针对UE Context Release流程，填写UE Context Release Request或UE Context Release Command消息中的Cause值。\n详见5.3.2.2.15", null, null, null, null, null, null, null, null
  failure_cause_type, int, "标识流程失败响应消息中cause字段所对应的Cause Group。\n失败原因类型，对于5G NAS流程：\n1：5GMM\n2：5GSM\n对于NGAP流程：\n1：Radio Network Layer\n2：Transport Layer\n3：NAS\n4：Protocol\n5：Misc\n对于SMS流程：\n1：CP Cause\n2：RP Cause", null, null, null, null, null, null, null, null
  failure_cause, int, "流程失败响应消息中的值。\nCauseValue，规范参见：\n> 5GMM具体CauseValue取值参见3GPP 24.501第9.11.3.2节Table 9.11.3.2.1；\n> 5GSM具体CauseValue取值参见3GPP 24.501第9.11.4.2节Table 9.11.4.2.1；\n> NGAP具体CauseValue取值参见3GPP 38.413第9.3.1.2节；\n详见5.3.2.2.16", null, null, null, null, null, null, null, null
