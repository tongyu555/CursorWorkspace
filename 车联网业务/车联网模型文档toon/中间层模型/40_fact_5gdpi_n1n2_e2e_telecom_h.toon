  ci, bigint, 流程结束时，UE所在的NR Cell ID/E-UTRAN Cell ID, null, null, null, null, null, null, null, null
  first_fail_trans_prot, int, "N1/N2接口信令流程中第一个失败的事务的协议层：\n0：NGAP\n1：5GSM\n2：5GMM\n如Registration流程中，发生鉴权失败，则填充鉴权失败的信息。", null, null, null, null, null, null, null, null
  first_fail_trans, int, 流程类型，具体取值参见附录K，由采集层填充, null, null, null, null, null, null, null, null
  first_fail_direction, int, "N1/N2接口信令流程中第一个失败的事务方向。\n1：失败事务由AN发起\n2：失败事务由AMF发起", null, null, null, null, null, null, null, null
  first_fail_cause_type, int, "标识流程失败响应消息中cause字段所对应的Cause Group。\n失败原因类型，对于5G NAS流程：\n1：5GMM\n2：5GSM\n对于NGAP流程：\n1：Radio Network Layer\n2：Transport Layer\n3：NAS\n4：Protocol\n5：Misc", null, null, null, null, null, null, null, null
  first_fail_cause, int, 信令流程中第一个失败的事务原因码，即信令流程失败的直接原因，从失败消息的Cause信元中获取, null, null, null, null, null, null, null, null
  e2e_first_fail_trans_prot, int, "全流程第一拆线事务的协议，由合成层实现多接口关联后填写。\n0：NGAP，标识第一拆线事务为N1/N2接口事务；\n1：HTTP2，标识第一拆线事务为服务化接口事务。", null, null, null, null, null, null, null, null
  e2e_first_fail_trans, int, "全流程第一拆线事务类型，由合成层实现多接口关联后填写。\n如E2E first fail trans prot字段为0：NGAP，则填充First fail trans；\n如E2E first fail trans prot字段为1：HTTP2，则填充服务化接口单据中的Procedure Type字段。", null, null, null, null, null, null, null, null
  e2e_first_fail_cause_type, int, "全流程第一拆线事务失败原因的类型，由合成层实现多接口关联后填写。\nN1/N2事务，填充first fail cause type字段值\n服务化接口，填充对应单据的status code字段值", null, null, null, null, null, null, null, null
  e2e_first_fail_cause, int, "全流程第一拆线事务失败原因码，从失败的事务中获取，由合成层实现多接口关联后填写。\nN1/N2事务，填充first fail cause字段值\n服务化接口，填充对应单据的failure cause字段值。\n", null, null, null, null, null, null, null, null
  pdu_session_number, int, 必填字段。整数值N，指示后续跟随的PDU Session信息的个数，每个PDU Session信息与一个会话相对应，其中包括以下多个字段： PDU Session ID，PDU Session Dnn，PDU Session 1 DNN type，操作结果，该PDU Session对应的用户面UPF侧及gNB侧的IP以及GTP-TEID。如果该信令过程不涉及对任何承载的操作，则该字段取值为0，此时该字段之后PDU Session信息的个数为0, null, null, null, null, null, null, null, null
  pdu_session_id, int, 第1个PDU Session Identity, null, null, null, null, null, null, null, null
  pdu_session_req_type, int, "第1个请求消息中的Request Type：\n1：initial request\n2：existing PDU session\n3：initial emergency request\n4：existing emergency PDU session\n5：modification request\n取值参见3GPP TS 24.501第9.11.3.47节", null, null, null, null, null, null, null, null
  pdu_session_type, int, "第1个应答消息中的PDU Session Type，取值:\n1：IPv4\n2：IPv6\n3：IPv4v6\n4：Unstructured\n5：Ethernet", null, null, null, null, null, null, null, null
