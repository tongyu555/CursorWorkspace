fields[41]{PDM字段英文名, PDM字段类型, PDM字段中文名（说明）, 源表名, 源字段英文名, 算法加工逻辑, 关联与过滤条件, 备注, 字段属性, 单位, 取值范围}:
  provincecode, int, 省, null, null, null, null, null, null, null, null
  day, string, 天, null, null, null, null, null, null, null, null
  msisdn, string, 用户号码, ab, null, null, null, null, null, null, null
  imsi, string, 用户imsi, ab, null, null, null, null, null, null, null
