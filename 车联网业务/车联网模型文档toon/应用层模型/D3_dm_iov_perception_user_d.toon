  car_brand, string, 汽车品牌, c, brand, 直取, null, null, null, null, null
  car_model, string, 汽车型号, c, brand_model, 直取, null, null, null, null, null
  odsStatus, string, 终端产品状态, c, null, null, null, 暂无, null, null, null
  active_date, string, 用户入网日期, c, null, null, null, 暂无, null, null, null
  nr_residency_ratio, double, 5G驻留比, ab, null, sum(b.service_duration)/sum(a.service_duration+b.service_duration), null, null, null, null, null
  nr_split_ratio, double, 5G分流比, ab, null, sum(b.service_flux)/sum(a.service_flux+b.service_flux), null, null, null, null, null
  cover_score, double, 覆盖感知评分, ab, null, (1-sum(a.less110_rsrp_cnt+b.less110_ssrsrp_cnt)/sum(a.total_rsrp_cnt+b.total_ssrsrp_cnt))*100, null, null, null, null, null
  data_score, double, 数据业务评分, ab, null, (1-sum(a.total_badcnt+b.total_badcnt)/sum(a.total_cnt+b.total_cnt))*100, null, null, null, null, null
  event_score, double, 性能感知评分, ab, null, null, null, null, null, null, null
  voice_score, double, 语音感知评分, ab, null, null, null, null, null, null, null
  cps, double, 综合感知评分, ab, null, 本表cover_score*data_score/100, null, null, null, null, null
  lte_cover_score, double, 4g覆盖感知评分, a, null, (1-sum(less110_rsrp_cn)/sum(total_rsrp_cnt))*100, null, null, null, null, null
  lte_data_score, double, 4g数据业务评分, a, null, (1-sum(total_badcnt)/sum(total_cnt))*100, null, null, null, null, null
  lte_event_score, double, 4g性能感知评分, a, null, null, null, null, null, null, null
  lte_voice_score, double, 4g语音感知评分, a, null, null, null, null, null, null, null
  lte_cps, double, 4g综合感知评分, a, null, 本表lte_cover_score*lte_data_score/100, null, null, null, null, null
  nr_cover_score, double, 5g覆盖感知评分, b, null, (1-sum(less110_ssrsrp_cnt)/sum(total_ssrsrp_cnt))*100, null, null, null, null, null
  nr_data_score, double, 5g数据业务评分, b, null, (1-sum(total_badcnt)/sum(total_cnt))*100, null, null, null, null, null
  nr_event_score, double, 5g性能感知评分, b, null, null, null, null, null, null, null
  nr_voice_score, double, 5g语音感知评分, b, null, null, null, null, null, null, null
  nr_cps, double, 5g综合感知评分, b, null, 本表nr_cover_score*nr_data_score/100, null, null, null, null, null
  lte_cell_cnt, double, 4G占用小区数, a, null, count(distinct(cellkey)), null, null, null, null, null
  nr_cell_cnt, double, 5G占用小区数, b, null, count(distinct(cellkey)), null, null, null, null, null
