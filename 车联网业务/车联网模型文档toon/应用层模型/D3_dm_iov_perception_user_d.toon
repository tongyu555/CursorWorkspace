  sp_issue_cnt, bigint, SP服务商问题数, ab, null, 暂置null，等算法, null, 如果>0，页面显示标识为异常, null, null, null
  attach_succ_ratio, double, 附着成功率, ab, null, "sum(nvl(a.attach_suc,0)+nvl(b.regis_suc,0))/sum(nvl(a.attach_req,0)+nvl(b.regis_req,0))", null, null, null, null, null
  data_drop_ratio, double, 掉线率（UE上下文掉线率）, ab, null, "sum(nvl(a.uecntx_abnormrel,0)+nvl(b.ue_contextrelease,0)-nvl(b.ue_normalcontextrelease,0))/sum(nvl(a.uecntx_abnormrel,0)+nvl(a.uecntx_normrel,0)+nvl(b.ue_contextrelease,0))", null, null, null, null, null
  handover_succ_ratio, double, 切换成功率（系统内）, ab, null, "sum(nvl(a.ho_succoutintraenb,0)+nvl(b.ho_succsamefreq,0)+nvl(b.ho_succdifffreq,0))/sum(nvl(a.ho_attsamefreq,0)+nvl(b.ho_attdifffreq,0)+nvl(b.ho_attoutintraenb,0))", null, null, null, null, null
