  nr_cover_ratio, double, 5G mr覆盖率, b, null, 1-sum(less110_ssrsrp_cnt)/sum(total_ssrsrp_cnt), null, null, null, null, null
  lte_rerp_avg, double, 4G 平均RSRP, a, null, sum(avg_rsrp*total_rsrp_cnt)/sum(total_rsrp_cnt), null, null, null, null, null
  nr_rerp_avg, double, 5G 平均RSRP, b, null, sum(avg_rsrp*total_ssrsrp_cnt)/sum(total_ssrsrp_cnt), null, null, null, null, null
  user_issue_cnt, bigint, 用户问题数, ab, null, 暂置null，等算法, null, 如果>0，页面显示标识为异常, null, null, null
  wireless_issue_cnt, bigint, 无线问题数, ab, null, 暂置null，等算法, null, 如果>0，页面显示标识为异常, null, null, null
