theme_domain: 45G-MR
table_name: fact_45gmr_user_trips_main_d
table_name_chinese: 45G用户出行轨迹概览表
data_frequency: day
primary_key: 数据库索引
source_table_name[1]{源表英文名, 源表中文名, 备注, 是否主表}:
  ods_45gmr_location_h, 45G用户经纬度回填表, "数据加工逻辑：\n1、首先根据mdn分组\n2、组内根据时间进行分段，间隔15分钟没没有mr上报，视为一段\n3、根据开始时间排序，生成路段id", 是
fields[16]{PDM字段英文名, PDM字段类型, PDM字段中文名（说明）, 源表名, 源字段英文名, 算法加工逻辑, 关联与过滤条件, 备注, 字段属性, 单位, 取值范围}:
  segment_id, string, 用户路段id，例如13512123456#20240904#1, null, null, 反转(mdn)#(p_date)#segment_rn, null, 反转是为了避免数据倾斜, null, null, null
  mdn, string, 用户号码, null, null, null, null, null, null, null, null
  imsi, string, 国际移动用户识别码, null, null, null, null, null, null, null, null
  segment_rn, int, "用户行程次序，如：1,2,3", null, null, 单用户15分钟内没有上报mr，或者识别为停驻，则生成新的路段id, null, null, null, null, null
  start_time, long, 路段开始时间(13位), null, null, null, null, null, null, null, null
  start_lon, double, 开始经度, null, null, null, null, null, null, null, null
  start_lat, double, 开始纬度, null, null, null, null, null, null, null, null
  start_cell_key, string, 开始小区，示例12432_1, null, null, null, null, null, null, null, null
  end_time, long, 路段结束时间(13位), null, null, null, null, null, null, null, null
  end_lon, double, 结束经度, null, null, null, null, null, null, null, null
  end_lat, double, 结束纬度, null, null, null, null, null, null, null, null
  end_cell_key, string, 结束小区，示例12432_1, null, null, null, null, null, null, null, null
  is_infer, int, 是否为推测路段，1是，0否, null, null, 当两个相邻mr在时间上断开15分钟，且距离超过2km，则标注为1，否则为0, null, null, null, null, null
  action_type, int, "1:移动，0：停驻", null, null, 0：该行程内用户停驻在同一个点附近, null, null, null, null, null
  date_time, string, 数据时间, null, null, 对start_time进行格式化, null, "示例：2017-07-17T00:55:000", null, null, null
  etl_time, string, 加工时间, null, null, null, null, "示例：2017-07-17T00:55:000", null, null, null