data_frequency: day
primary_key: 数据库索引
source_table_name[1]{源表英文名, 源表中文名, 备注, 是否主表}:
  fact_45gmr_user_trips_detail_d, 45G用户轨迹明细表, "1、取滤波后的经纬度\n2、静止的多个点只保留一个\n3、运动的点匹配到多个道路", 是
fields[16]{PDM字段英文名, PDM字段类型, PDM字段中文名（说明）, 源表名, 源字段英文名, 算法加工逻辑, 关联与过滤条件, 备注, 字段属性, 单位, 取值范围}:
  mdn, string, 用户号码, null, null, null, null, null, null, null, null
  imsi, string, 国际移动用户识别码, null, null, null, null, null, null, null, null
  segment_id, string, 用户路段id，例如13512123456#20240904#1, null, null, 反转(mdn)#(p_date)#segment_rn, null, null, null, null, null
  segment_rn, int, "用户行程次序，如：1,2,3", null, null, null, null, null, null, null, null
  datetime, List<long>, 测量时间，同一个端点有多个时间时，用$隔开, null, null, null, null, null, null, null, null
  route_point_id, string, 匹配的道路端点id（可以应用于路径规划）, null, null, null, null, null, null, null, null
  route_point_lon, double, 道路端点经度, null, null, null, null, null, null, null, null
  route_point_lat, double, 道路端点维度, null, null, null, null, null, null, null, null
  rsrp, float, rsrp, null, null, 取平均值, null, null, null, null, null
  rsrq, float, rsrq, null, null, 取平均值, null, null, null, null, null
  enodebid, int, 基站enodebid, null, null, null, null, null, null, null, null
  cellid, int, 基站cellid, null, null, null, null, null, null, null, null
  rattype, string, 网络类型（4G、5G）, null, null, null, null, null, null, null, null
  p_region, int, 厂商分区, null, null, null, null, null, null, null, null
  mr_cnt, int, mr 个数, null, null, null, null, null, null, null, null
  etl_time, string, "表加工时间（示例：2017-07-17T00:55:000）", null, null, null, null, null, null, null, null