theme_domain: 45G-MR
table_name: fact_45gmr_user_trips_detail_d
table_name_chinese: 45G用户轨迹明细表
data_frequency: day
primary_key: 数据库索引
source_table_name[1]{源表英文名, 源表中文名, 备注, 是否主表}:
  ods_45gmr_location_h, 45G用户经纬度回填表, "数据处理逻辑：\n1、根据mdn分组\n2、组内根据时间进行分段，间隔10分钟没没有mr上报，视为一段\n3、分段进行动静识别，然后打标\n4、分别对静止点和运动点进行滤波", 是
fields[25]{PDM字段英文名, PDM字段类型, PDM字段中文名（说明）, 源表名, 源字段英文名, 算法加工逻辑, 关联与过滤条件, 备注, 字段属性, 单位, 取值范围}:
  mdn, string, 用户号码, null, null, null, null, null, null, null, null
  imsi, string, 国际移动用户识别码, null, null, null, null, null, null, null, null
  segment_id, string, 用户路段id，例如13512123456#20240904#1, null, null, 反转(mdn)#p_date#segment_rn, null, null, null, null, null
  segment_rn, int, "用户行程次序，如：1,2,3", null, null, null, null, null, null, null, null
  datetime, long, 测量时间, null, null, null, null, null, null, null, null
  enodebid, integer, 基站ID, null, null, null, null, null, null, null, null
  cellid, integer, 小区ID, null, null, null, null, null, null, null, null
  plmn, string, UE 接入E-utran网络使用的PLMN, null, null, null, null, null, null, null, null
  rsrp, int, 服务小区Rsrp, null, null, null, null, null, null, null, null
  rsrq, tinyint, 服务小区Rsrq, null, null, null, null, null, null, null, null
  ta, int, "默认TUeCmacLocation.swTaDvType1 V3.4后开启TAResult开关，\n输出TUeCmacLocation.TAResult/16", null, null, null, null, null, null, null, null
  mrlon, double, MR 经度 非AGPS数据定位回填, null, null, null, null, null, null, null, null
  mrlat, double, MR 纬度 非AGPS数据定位回填, null, null, null, null, null, null, null, null
  locationtype, int, 定位类型, null, null, null, null, null, null, null, null
  action_type, int, 运动状态，0：静止，1：运动, null, null, 使用dbscan进行动静识别打标, null, null, null, null, null
  stop_rn, int, 用户停留次序，如1、2、3, null, null, 对打标为静止的点进行分类，按照时间排序, null, null, null, null, null
  speed, int, 速度，m/s, null, null, 与前一个点的距离/时间, null, null, null, null, null
  lon_predict, double, 滤波后的经度, null, null, null, null, null, null, null, null
  lat_predict, double, 滤波后的纬度, null, null, null, null, null, null, null, null
  route_point_id, string, 匹配的道路端点id（可以应用于路径规划）, null, null, 将修正后的lon、lat映射到路网端点上, null, null, null, null, null
  route_point_lon, double, 道路端点经度, null, null, null, null, null, null, null, null
  route_point_lat, double, 道路端点维度, null, null, null, null, null, null, null, null
  rattype, int, 网络类型（4G、5G）, null, null, null, null, null, null, null, null
  date_time_format, string, 数据时间（格式化后）, null, null, null, null, null, null, null, null
  etl_time, string, "表加工时间（示例：2017-07-17T00:55:000）", null, null, null, null, null, null, null, null