  'serialization.format' = ','
)
;

-- parquet 格式存储
CREATE EXTERNAL TABLE `zxvmax`.`dm_4gcm_datacheck_lt_index_d`
(
    `day` string,
    `provincecode` int,
    `province_name` string,
    `cucc_cellnum_avg` int,
    `cucc_cellnum_current` int,
    `cucc_cellnum_change_rate` double,
    `cucc_cell_lon_nonnull_rate` double,
    `cucc_cell_lat_nonnull_rate` double,
    `cucc_cell_height_nonnull_rate` double,
    `cucc_azimuth_nonnull_rate` double,
    `cucc_provincecode_nonnull_rate` double,
    `cucc_citycode_nonnull_rate` double,
    `cucc_districtcode_nonnull_rate` double,
    `is_abnormal_cucc_cellnum` int,
    `is_abnormal_cucc_cell_lon` int,
    `is_abnormal_cucc_cell_lat` int,
    `is_abnormal_cucc_cell_height` int,
    `is_abnormal_cucc_azimuth` int,
    `is_abnormal_cucc_provincecode` int,
    `is_abnormal_cucc_citycode` int,
    `is_abnormal_cucc_districtcode` int,
    `completion_rate` double,
    `check_result` int
)
PARTITIONED BY (`p_provincecode` INT, `p_date` STRING)
ROW FORMAT SERDE 'org.apache.hadoop.hive.ql.io.parquet.serde.ParquetHiveSerDe'
WITH SERDEPROPERTIES (
  'serialization.format' = '1'
)
STORED AS
  INPUTFORMAT 'org.apache.hadoop.hive.ql.io.parquet.MapredParquetInputFormat'
  OUTPUTFORMAT 'org.apache.hadoop.hive.ql.io.parquet.MapredParquetOutputFormat'
LOCATION 'viewfs://nsX/vmax_ns4/zxvmax/telecom/lte/dm/dm_4gcm_datacheck_lt_index_d'
TBLPROPERTIES (
  'colelction.delim' = '|',
  'field.delim' = ',',
  'serialization.format' = ',',
  'parquet.compression' = 'SNAPPY'
)
;