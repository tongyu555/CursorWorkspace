  district, string, 区县名称, B, district, 关联工参回填, null, null, 详单, 无, 无
  sourceip_type, string, 用户访问外部网络时使用的IP类型（IPv4/IPv6）, A, null, "根据sourceip字段结果识别\ncase when sourceip regexp '^((25[0-5]|2[0-4]\\\\d|[01]?\\\\d\\\\d?)\\\\.){3}(25[0-5]|2[0-4]\\\\d|[01]?\\\\d\\\\d?)$' then 'ipv4' when sourceIP regexp '^([\\\\da-fA-F]{1,4}:){7}[\\\\da-fA-F]{1,4}$' then 'ipv6' else '' end as sourceip_type", null, null, 详单, 无, 无
  tcpsetupdelay, bigint, TCP建立时延, A, null, case when tcpsetupresponsedelay >0  and tcpsetupackdelay >0 and (tcpsetupresponsedelay+tcpsetupackdelay) <50000 then  tcpsetupresponsedelay+tcpsetupackdelay else null end, null, 现网算法（无明显变更）：case when tcpsetupresponsedelay<50000 and tcpsetupackdelay<50000 then (tcpsetupresponsedelay+tcpsetupackdelay) else null end, 详单, ms, "(0,50000)"
  videothroughput_custom, bigint, 自定义视频下载速率(剔除video_size<500KB), A, null, case when videoplaysuccess = 1 and videothroughput>0 and videothroughput<=307200 and videosize>=512000 and  and  then videothroughput else null end, null, null, 详单, 无, 无
  videocachethroughput_custom, bigint, 自定义视频缓冲段下载速率(剔除video_size<500KB), A, null, case when videoplaysuccess = 1 and videocachethroughput>0 and videocachethroughput<=307200 and videosize>=512000 then videocachethroughput else null end, null, null, 详单, 无, 无
  videoplayhaltcount_custom, bigint, 自定义视频播放卡顿次数(剔除video_size<500KB)(计算视频卡顿频次), A, null, case when videoplaysuccess = 1 and videothroughput>0 and videothroughput<=307200 and videosize>=512000 and videobitrate>0 and (videoplayhaltcount)/(inputoctets*8/(videobitrate*1000)/60)<=10 then videoplayhaltcount else 0 end, null, null, 详单, 无, 无
  video_play_duration_custom, double, 自定义视频播放时长(剔除video_size<500KB)-分钟(计算视频卡顿频次), A, null, case when videoplaysuccess = 1 and videothroughput>0 and videothroughput<=1024000 and videosize>=512000 and videobitrate>0 and (videoplayhaltcount)/(inputoctets*8/(videobitrate*1000)/60)<=10 then (inputoctets*8/(videobitrate*1000)/60) else 0 end, null, null, 详单, 分钟, >=0
  videoplayhaltcountpermin_custom, double, 自定义视频播放卡顿频次(次/分钟), A, null, case when videoplaysuccess = 1 and videothroughput>0 and videothroughput<=307200 and videosize>=512000 and videobitrate>0 and (videoplayhaltcount)/(inputoctets*8/(videobitrate*1000)/60)<=10 then (videoplayhaltcount)/(inputoctets*8/(videobitrate*1000)/60) else 0 end, null, null, 详单, 次/分钟, >=0
  video_play_duration, double, 视频播放时长-分钟(计算视频卡顿频次), A, null, case when videoplaysuccess = 1 and videothroughput>0 and videothroughput<=307200 and videobitrate>0 and videoplayhaltcount/(inputoctets*8/(videobitrate*1000)/60)<=10 then (inputoctets*8/(videobitrate*1000)/60) else 0 end, null, null, 详单, 分钟, >=0
  videoplayhaltcountpermin, double, 视频播放卡顿频次(次/分钟), A, null, case when videoplaysuccess = 1 and videothroughput>0 and videothroughput<=307200 and videobitrate>0 and videoplayhaltcount/(inputoctets*8/(videobitrate*1000)/60)<=10 then videoplayhaltcount/(inputoctets*8/(videobitrate*1000)/60) else 0 end, null, null, 详单, 次/分钟, >=0
  videothroughput_cnt, bigint, 视频下载速率次数, A, null, case when videoplaysuccess = 1 and videothroughput>0 and videothroughput<=307200 then 1 else 0 end, null, null, 详单, 无, 无
  videocachethroughput_cnt, bigint, 视频缓冲段下载速率次数, A, null, case when videoplaysuccess = 1 and videocachethroughput>0 and videocachethroughput<=307200 then 1 else 0 end, null, null, 详单, 无, 无
  is_abnormal, int, 是否质差话单, A, null, case when (tcpsetupresponsedelay>= 110  and tcpsetupresponsedelay<50000) or (tcpsetupackdelay>=110  and tcpsetupackdelay<50000)  or  ultcp_retranspacket/outputpacket>=0.15 or dltcp_retranspacket/inputpacket>=0.15 then 1 else 0 end, null, null, 详单, 无, "1,0"
  is_core_delimit, int, 是否核心网问题, A, null, case when (tcpsetupresponsedelay>=110 and tcpsetupresponsedelay<50000)  or ultcp_retranspacket/outputpacket>0.15 then 1 else 0 end, null, null, 详单, 无, "1,0"
  is_wireless_delimit, int, 是否无线网络问题, A, null, case when (tcpsetupackdelay>=110 and tcpsetupackdelay<50000)  or dltcp_retranspacket/inputpacket>0.15 then 1 else 0 end, null, null, 详单, 无, "1,0"
