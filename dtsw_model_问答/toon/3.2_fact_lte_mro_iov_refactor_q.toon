theme_domain: /
table_name: fact_lte_mro_iov_refactor_q
table_name_chinese: 电联4G车载用户MRO事实表
data_frequency: 15分钟
primary_key: 数据描述
source_table_name[2]{源表英文名, 源表中文名, 别名, 任务描述}:
  fact_lte_mro_usrbackfill_q, 4G电联MRO用户回填详单表, A, null
  cfg_iov_usr_list, 车联网用户清单配置表, B, A inner join B，关联条件：A.msisdn = B.msisdn
fields[15]{PDM字段英文名, PDM字段类型, PDM字段中文名（说明）, 源表名, 源字段英文名, 算法加工逻辑, 关联与过滤条件, 备注, 字段属性, 单位, 取值范围}:
  datetime, string, 样本数据测量对象UE的样本测量时间，UTC时间格式。对MRO文件，取值为测量采样周期的整数倍，上报时间采用 UTC 时间进行计算。, A, datetime, 直取, null, null, null, null, null
  enodebid, int, 字符串，取值为eNodeB Id。, A, enodebid, 直取, null, null, null, null, null
  cellid, int, "标识具体的测量对象。若为小区对象，则采用CellId (8bit)表示；若为子帧对象，则采用“CellId:Earfcn:SubFrameNbr”表示；若为PRB对象，则采用“CellId:Earfcn:SubFrameNbr:PRBNbr”表示。表示测量报告样本数据时，采用主服务小区CellId或子帧对象进行标识。", A, cellid, 直取, null, null, null, null, null
  imsi, string, 用户IMSI串号, A, imsi, 直取, null, null, null, null, null
  mdn, string, 用户电话号码, A, mdn, "REGEXP_REPLACE(CAST(mdn AS STRING), '^86', '')", null, null, null, null, null
  rsrp, smallint, UE收到服务小区的参考信号接收功率。小区专属参考信号R0 将用于决定RSRP。如果UE能可靠地检测到小区专属参考信号R1 可用，那么可以使用R0 和R1 决定RSRP。如果 UE 使用接收分集，报告值应该不低于任一独立分集分支的相应RSRP值。取值范围0-97。, A, rsrp, rsrp+140, null, null, null, null, null
  rsrq, tinyint, UE收到服务小区的参考信号接收质量。取值范围0-34。, A, rsrq, rsrq*2+40, null, null, null, null, null
  ta, int, 服务小区时间提前量，指UE到服务基站的信号传播时间。, A, ta, 直取, null, null, null, null, null
  plmn, string, UE接入E-utran网络使用的PLMN号。, A, plmn, 直取, null, null, null, null, null
  mrlon, double, MR 经度 非AGPS数据定位回填, A, mrlon, 直取, null, null, null, null, null
  mrlat, double, MR 纬度 非AGPS数据定位回填, A, mrlat, 直取, null, null, null, null, null
  locationtype, int, 定位类型, A, locationtype, 直取, null, null, null, null, null
  regionid, int, RegionID, A, regionid, 直取, null, null, null, null, null
  x_offset_original, int, X偏移, A, x_offset_original, 直取, null, null, null, null, null
  y_offset_original, int, Y偏移, A, y_offset_original, 直取, null, null, null, null, null