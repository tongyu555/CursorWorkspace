theme_domain: 数据感知
table_name: aggr_lte_dpi_dns_base_q
table_name_chinese: 4G_DPI_dns基础维度15分钟表
data_frequency: quarter
primary_key: 数据描述
source_table_name[2]{源表英文名, 源表中文名, 别名, 是否主表, 任务描述, 备注}:
  ods_4gdpi_dns_e2e_telecom_q, 4G_DPI_dns贴源层详单表, A, 是, null, null
  lte_cm_projdata_refactor, 4G电联工参表, B, null, 先按cellkey去重, "关联条件：concat(floor(cast(split(ecgi, '-')[2] as int)/256),\"_\",cast(split(ecgi, '-')[2] as int)%256)=B.reportcellkey"
fields[48]{PDM字段英文名, PDM字段类型, PDM字段中文名（说明）, 源表名, 源字段英文名, 算法加工逻辑, 关联与过滤条件, 备注, 字段属性, 单位, 取值范围}:
  day, string, 日期, A, p_date, 直取, null, null, 维度, 无, yyyy-mm-dd
  hour, int, 小时, A, p_hour, 直取, null, null, 维度, 无, 0~23
  quarter, int, 15分钟, A, p_quarter, 直取, null, null, 维度, 无, 0~3
  interface, int, 接口类型, A, interface, 直取, null, null, 维度, 无, <=101
  rattype, int, 网络类型（4G：6；5G：10）, A, rattype, 直取, null, null, 维度, 无, "6,10"
  provincecode, int, 省编码, A, p_provincecode, 直取, null, null, 维度, 无, 6位数编码
  citycode, int, 市编码, B, citycode, 关联工参回填, null, null, 维度, 无, 6位数编码
  districtcode, int, 区编码, B, districtcode, 关联工参回填, null, null, 维度, 无, 6位数编码
  province, string, 省名称, B, province, 关联工参回填, null, null, 维度, 无, 无
  city, string, 地市名称, B, city, 关联工参回填, null, null, 维度, 无, 无
  district, string, 区县名称, B, district, 关联工参回填, null, null, 维度, 无, 无
  cellkey, string, 小区cellkey, A, null, "concat(floor(cast(split(ecgi, '-')[2] as int)/256),\"_\",cast(split(ecgi, '-')[2] as int)%256)", null, "ecgi：\n460-11-239188563", 维度, 无, 无
  imsi, string, 用户imsi, A, imsi, 直取, null, null, 维度, 无, 无
  msisdn, string, 用户号码, A, null, "regexp_replace(trim(msisdn),'^86','')", null, null, 维度, 无, 无
  imei, string, 用户终端, A, imei, 直取, null, null, 维度, 无, 无
  apn, string, 网络接入技术, A, apn, 直取, null, null, 维度, 无, 无
  mmeip, string, MME的IPv4或IPv6地址, A, mmeip, 直取, null, null, 维度, 无, 无
  sgwip, string, SGW的IPv4或IPv6地址, A, sgwip, 直取, null, null, 维度, 无, 无
  pgwip, string, PGW的IPv4或者IPv6的地址, A, pgwip, 直取, null, null, 维度, 无, 无
  servicetype, string, 业务应用, A, servicetype, 直取, null, null, 维度, 无, 无
  enbip, string, gNB的IPv4或IPv6地址, A, enbip, 直取, null, null, 维度, 无, 无
  home_province, string, 归属省份, A, home_province, 直取, null, null, 维度, 无, 6位数编码
  l4protocol, int, L4协议类型： 0：TCP；1：UDP, A, l4protocal, 直取, null, null, 维度, 无, "0,1"
  bearer_qci, int, 承载的QCI，取值范围从1到9, A, bearer_qci, 直取, null, null, 维度, 无, 无
  sourceip_type, string, 用户访问外部网络时使用的IP类型（IPv4/IPv6）, A, null, 根据sourceip字段结果识别, null, "case when sourceip regexp '^((25[0-5]|2[0-4]\\\\d|[01]?\\\\d\\\\d?)\\\\.){3}(25[0-5]|2[0-4]\\\\d|[01]?\\\\d\\\\d?)$' then 'ipv4' when sourceIP regexp '^([\\\\da-fA-F]{1,4}:){7}[\\\\da-fA-F]{1,4}$' then 'ipv6' else '' end as sourceip_type", 维度, 无, 无
  dnssuctime_sum, bigint, DNS查询成功时延_求和, A, null, sum(case when replycode=0 and responsetime- querytime>0 and responsetime- querytime<30000 then responsetime- querytime else null end), null, null, 指标, 无, >=0
  dnssuc_over2s_cnt, bigint, DNS查询时延>2s次数, A, null, sum(case when replycode=0 and responsetime- querytime>2000 then  1 else 0 end), null, null, 指标, 无, >=0
  replycode1_cnt, bigint, DNS格式错误次数, A, null, sum(case when replycode=1  then 1 else 0 end), null, null, 指标, 无, >=0
  replycode2_cnt, bigint, DNS服务器错误次数, A, null, sum(case when replycode=2  then 1 else 0 end), null, null, 指标, 无, >=0
  replycode3_cnt, bigint, DNS域名错误次数, A, null, sum(case when replycode=3  then 1 else 0 end), null, null, 指标, 无, >=0
  replycode4_cnt, bigint, DNS未实现次数, A, null, sum(case when replycode=4  then 1 else 0 end), null, null, 指标, 无, >=0
  replycode5_cnt, bigint, DNS服务器拒绝次数, A, null, sum(case when replycode=5  then 1 else 0 end), null, null, 指标, 无, >=0
  replycode_null_cnt, bigint, DNS无响应次数, A, null, sum(case when replycode is null  then 1 else 0 end), null, null, 指标, 无, >=0
  xdr_suc_cnt, bigint, xdr成功条数, A, null, sum(case when tcpconnectstate=0 or sessionstopflag=1 then 1 else 0 end), null, null, 指标, 无, >=0
  abnormal_cnt, bigint, 质差话单数量, A, null, sum(case when tcpsetupresponsedelay>= 110 or tcpsetupackdelay>=110  or ultcp_retranspacket/outputpacket>=0.15 or dltcp_retranspacket/inputpacket>=0.15  then 1 else 0 end), null, null, 指标, 无, >=0
  dns_query_cnt, int, DNS请求次数, A, null, count(1), null, null, 指标, 无, >=0
  dns_suc_cnt, int, DNS成功次数, A, null, sum(case when reply_code=0  then 1 else 0 end), null, null, 指标, 无, >=0
  dns_delay, double, DNS时延, A, null, avg(case when responsetime- querytime < 30000 and responsetime- querytime > 0 then responsetime- querytime else null end), null, null, 指标, 无, >=0
  dns_delay_custom, double, DNS时延（自定义：剔除时延大于100ms的详单数据）, A, null, avg(case when (responsetime- querytime) < 100 and (responsetime- querytime) > 0 then (responsetime- querytime) else null end), null, null, 指标, 无, "[0,100]"
  dns_delay_cnt_0_50, bigint, "DNS查询时延在(0,50]的次数", A, null, sum(case when responsetime-querytime>0 and responsetime-querytime<=50 then 1 else 0 end), null, null, 指标, 无, >=0
  dns_delay_cnt_50_100, bigint, "DNS查询时延在(50,100]的次数", A, null, sum(case when responsetime-querytime>50 and responsetime-querytime<=100 then 1 else 0 end), null, null, 指标, 无, >=0
  dns_delay_cnt_100_150, bigint, "DNS查询时延在(100,150]的次数", A, null, sum(case when responsetime-querytime>100 and responsetime-querytime<=150 then 1 else 0 end), null, null, 指标, 无, >=0
  dns_delay_cnt_150_200, bigint, "DNS查询时延在(150,200]的次数", A, null, sum(case when responsetime-querytime>150 and responsetime-querytime<=200 then 1 else 0 end), null, null, 指标, 无, >=0
  dns_delay_cnt_greater_200, bigint, "DNS查询时延在(200,200000]的次数", A, null, sum(case when responsetime-querytime>200 and responsetime-querytime<=200000 then 1 else 0 end), null, null, 指标, 无, >=0
  p_provincecode, int, 省分区, null, null, null, null, null, null, null, null
  p_date, string, 天分区, null, null, null, null, null, null, null, null
  p_hour, int, 小时分区, null, null, null, null, null, null, null, null
  p_quarter, int, 15分钟分区, null, null, null, null, null, null, null, null