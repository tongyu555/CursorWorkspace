  datetime, string, 事件发生时间, B1/B2/B3B4, "B1:from_unixtime(substr(t1.procedure_starttime, 0, 10), 'yyyy-MM-dd HH:mm:ss')\nB2:date_format(datetime, 'yyyy-MM-dd HH:mm:ss')\nB3:date_format(datetime, 'yyyy-MM-dd HH:mm:ss')\nB4:from_unixtime(substr(procedure_start_time, 0, 10), 'yyyy-MM-dd HH:mm:ss')", null, null, null, null, null, null
