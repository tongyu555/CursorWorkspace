  mod3snpciflag, int, 与服务小区同频的邻区的PCI的模3值与服务小区的模3值相等, A, null, 主小区MOD3=邻小区MOD3：case when pci%3 = npci%3 then 1  else 0 end, null, null, 详单, 无, 无
  is_mod3interfer, int, 是否MOD3干扰采样点, A, null, "1、先计算出snearfcnflag、mod3srsrpflag、mod3snrsrpflag、mod3snpciflag\n2、case when snearfcnflag=1 and mod3srsrpflag=1 and mod3snrsrpflag=1 and mod3snpciflag=1 then 1 else 0 end", null, null, 详单, 无, 无
