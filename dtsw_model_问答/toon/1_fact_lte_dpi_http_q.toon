  syntime, bigint, "SYN 时间戳，UTC 时间，从 1970/1/1 00:00:00 开始到当前的毫秒数。", A, syntime, 直取, null, null, 详单, 无, 无
  synacktime, bigint, "SYNACK 时间戳，UTC 时间，从 1970/1/1 00:00:00 开始到当前的毫秒数。", A, synacktime, 直取, null, null, 详单, 无, 无
