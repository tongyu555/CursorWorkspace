  district, string, 区县名称, B, district, 关联工参回填, null, null, 详单, 无, 无
  http_req_cnt, bigint, http请求次数, A, null, case when httpstatus is not null then 1 else 0 end, null, null, 详单, 无, "1,0"
  http_succ_cnt, bigint, http请求成功次数, A, null, case when httpstatus>0 and httpstatus<400  then 1 else 0 end, null, null, 详单, 无, "1,0"
  http_complete_cnt, bigint, http请求完成次数, A, null, case when httpstatus>0 and httpstatus<400 and  lastpacktime>0 then 1 else 0 end, null, null, 详单, 无, "1,0"
  dnsresponse_delay, bigint, DNS响应时延, A, null, case when  dnsquerytime>0 and dnsresponsetime>dnsquerytime and dnsresponsetime - dnsquerytime < 30000 then  dnsresponsetime - dnsquerytime else null end, null, 现网算法（无明显变更）：case when dnsquerytime>0 and dnsresponsetime>0 and (dnsresponsetime-dnsquerytime)>=0 and (dnsresponsetime-dnsquerytime) <30000 then dnsresponsetime-dnsquerytime else 0 end, 详单, ms, "(0,30000)"
  syntime_dnsresponse_delay, bigint, DNS建立完成到TCP握手时延, A, null, case when  dnsresponsetime>0 and syntime>dnsresponsetime and syntime-dnsresponse<50000 then  syntime-dnsresponsetime else null end, null, 现网算法（算法存在变更）：null, 详单, ms, "(0,50000)"
  tcpsetupdelay, bigint, TCP建立时延, A, null, case when tcpsetupresponsedelay >0  and tcpsetupackdelay >0 and (tcpsetupresponsedelay+tcpsetupackdelay) <50000 then  tcpsetupresponsedelay+tcpsetupackdelay else null end, null, 现网算法（无明显变更）：tcp_resp_delay+tcp_ack_delay, 详单, ms, "(0,50000)"
  httpwebrspdelay, bigint, 网页首包时延，也叫网页响应时延, A, null, case when dnsquerytime>0 and firstpackettime>dnsquerytime and firstpackettime - dnsquerytime<100000 then firstpackettime - dnsquerytime when syntime>0 and firstpackettime>syntime and (firstpackettime - syntime) <100000 then (firstpackettime - syntime)   else null end, null, 现网算法（算法存在变更）：case when  DNSQueryTime >0 and FirstPacketTime>DNSQueryTime then FirstPacketTime-DNSQueryTime when SYNtime >0 and FirstPacketTime>SYNtime then FirstPacketTime-SYNtime   else null end as httpwebrspdelay, 详单, ms, "(0,10000)"
  httpwebdspdelay, bigint, 网页显示时延，也叫网页完整打开时延, A, null, case when dnsquerytime>0 and lastpacktime>dnsquerytime and lastpacktime - dnsquerytime<30000 then lastpacktime - dnsquerytime when syntime > 0 and lastpacktime > syntime and lastpacktime - syntime < 30000 then  lastpacktime-syntime   else null end, null, 现网算法（无明显变更）：case when DNSQueryTime>0 and Lastpacktime>DNSQueryTime then Lastpacktime-DNSQueryTime when syntime>0  and Lastpacktime>SYNtime then Lastpacktime-SYNtime   else null end as httpwebdspdelay, 详单, ms, "(0,10000)"
  httpwebscreendelay, bigint, 网页首屏时延, A, null, case when dnsquerytime>0 and firstscreenfintime>dnsquerytime and firstscreenfintime - dnsquerytime<100000 then firstscreenfintime - dnsquerytime when syntime >0  and firstscreenfintime>syntime and firstscreenfintime-syntime<100000 then firstscreenfintime-syntime   else null end, null, 现网算法（无明显变更）：case when  DNSQueryTime >0  and FirstScreenFinTime>DNSQueryTime then FirstScreenFinTime-DNSQueryTime when SYNtime>0 and FirstScreenFinTime>SYNtime then FirstScreenFinTime-SYNtime   else null end as httpwebscreendelay, 详单, ms, "(0,10000)"
  is_topweb_first_screen_host, int, 是否用于计算首屏时延的主流网址（1：是；0：否）, C, null, 通过host关联C表，能关联上则取1，否则取0, null, null, 详单, 无, "1,0"
  sourceip_type, string, 用户访问外部网络时使用的IP类型（IPv4/IPv6）, A, null, 根据sourceip回填属于IPV6/IPV4, null, "case when sourceip regexp '^((25[0-5]|2[0-4]\\\\d|[01]?\\\\d\\\\d?)\\\\.){3}(25[0-5]|2[0-4]\\\\d|[01]?\\\\d\\\\d?)$' then 'ipv4' when sourceip regexp '^([\\\\da-fA-F]{1,4}:){7}[\\\\da-fA-F]{1,4}$' then 'ipv6' else '' end as sourceip_type", 详单, 无, "ipv4,ipv6"
  business_type, string, 业务类型（im、web、game、video、other）, A, null, "1、先将微信扫码业务置为88888888，再分类\ncase when ((servicetype>=01000101 and servicetype<01999901) \n        or (servicetype>=04000100 and servicetype<04999901)\n        or (servicetype = 88888888)) \n       and (servicetype not in (01000212,01004600,01001300)) then 'im' \n     when ((servicetype>=13000100 and servicetype<13999901) \n        or (servicetype>=16000100 and servicetype<16999901) \n        or (servicetype>=10000101 and servicetype<10999901) \n        or (servicetype>=07000100 and servicetype<07999901) \n        or (servicetype>=19000100 and servicetype<19999901) \n        or (servicetype>=09000101 and servicetype<09999901) \n        or (servicetype>=06000101 and servicetype<06999901) \n        or (servicetype>=08000101 and servicetype<08999901) \n        or (servicetype>=11000101 and servicetype<11999901) \n        or (servicetype>=14000101 and servicetype<14999901) \n        or (servicetype>=17000101 and servicetype<17999901) \n        or (servicetype>=18000101 and servicetype<18999901)) \n        and (servicetyp not in (09000101,09000601,09000701,09000801,09001800,09001900,09002000,09001202,01000212,01001300,01004600,09000603)) then 'web' \n     when servicetype>=05000100 and servicetype<05999901 then 'game' \n     when (servicetype>=02000101 and servicetype<02999901) then 'video'\n     else 'other' end", null, null, 详单, 无, "im,web,game,video,other"
  is_abnormal, int, 是否质差话单, A, null, case when (tcpsetupresponsedelay>= 110  and tcpsetupresponsedelay<50000) or (tcpsetupackdelay>=110  and tcpsetupackdelay<50000)  or  ultcp_retranspacket/outputpacket>=0.15 or dltcp_retranspacket/inputpacket>=0.15 then 1 else 0 end, null, null, 详单, 无, "1,0"
  is_core_delimit, int, 是否核心网问题, A, null, case when (tcpsetupresponsedelay>=110 and tcpsetupresponsedelay<50000)  or ultcp_retranspacket/outputpacket>0.15 then 1 else 0 end, null, null, 详单, 无, "1,0"
  is_wireless_delimit, int, 是否无线网络问题, A, null, case when (tcpsetupackdelay>=110 and tcpsetupackdelay<50000)  or dltcp_retranspacket/inputpacket>0.15 then 1 else 0 end, null, null, 详单, 无, "1,0"
  is_usr_delimit, int, 是否用户问题, D, null, "A表与D表关联，取D表problem_demarcation。\ncase when problem_demarcation='用户' then 1 else 0 end", null, null, 详单, 无, "1,0"
  is_sp_delimit, int, 是否sp服务器问题, D, null, "A表与D表关联，取D表problem_demarcation。\ncase when problem_demarcation='SP服务商' then 1 else 0 end", null, null, 详单, 无, "1,0"
  httpstatus_position, string, http状态码原因定位, D, problem_position, 直取, null, null, 详单, 无, 无
