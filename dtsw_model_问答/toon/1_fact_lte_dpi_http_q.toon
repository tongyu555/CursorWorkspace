  actiontime, bigint, "首个 HTTP 请求的时间戳，UTC 时间，从 1970/1/1 00:00:00 开始到当前的毫秒数。", A, actiontime, 直取, null, null, 详单, 无, 无
  firstpackettime, bigint, "第一个数据响应包的时间戳，UTC 时间，从 1970/1/1 00:00:00 开始到当前的毫秒数。", A, firstpackettime, 直取, null, null, 详单, 无, 无
  pageopentime, bigint, "首页打开的时间戳，UTC 时间，从 1970/1/1 00:00:00 开始到当前的毫秒数。", A, pageopentime, 直取, null, null, 详单, 无, 无
  lastpacktime, bigint, "最后一个数据包时间戳，UTC 时间，从 1970/1/1 00:00:00 开始到当前的毫秒数。", A, lastpacktime, 直取, null, null, 详单, 无, 无
