  dnsquerytime, bigint, "DNS关联流的请求时间，UTC 时 间 ， 从 1970/1/1 00:00:00 开始到当前的毫秒数。", A, dnsquerytime, 直取, null, null, 详单, 无, 无
  dnsresponsetime, bigint, "DNS关联流的应答时间戳。无关联流，此字段填写0。UTC 时 间 ， 从 1970/1/1 00:00:00 开始到当前的毫秒数", A, dnsresponsetime, 直取, null, null, 详单, 无, 无
  dnsflowid, bigint, "HTTP流与DNS流的关联ID。无关联流，此字段填写0。UTC 时 间 ， 从 1970/1/1 00:00:00 开始到当前的毫秒数", A, dnsflowid, 直取, null, null, 详单, 无, 无
  firstscreenfintime, bigint, "首屏完成时间戳，默认值0。算法见《中国电信2017年移动互联网业务感知质量评价细则》。UTC 时 间 ， 从 1970/1/1 00:00:00 开始到当前的毫秒数。", A, firstscreenfintime, 直取, null, null, 详单, 无, 无
