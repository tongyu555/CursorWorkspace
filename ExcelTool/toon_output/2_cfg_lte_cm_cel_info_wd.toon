  province, string, 省名称, null, null, "CASE\n    WHEN $xxx.p_provincecode$ = 110000 THEN '北京'\n    WHEN $xxx.p_provincecode$ = 120000 THEN '天津'\n    WHEN $xxx.p_provincecode$ = 130000 THEN '河北'\n    WHEN $xxx.p_provincecode$ = 140000 THEN '山西'\n    WHEN $xxx.p_provincecode$ = 150000 THEN '内蒙古'\n    WHEN $xxx.p_provincecode$ = 210000 THEN '辽宁'\n    WHEN $xxx.p_provincecode$ = 220000 THEN '吉林'\n    WHEN $xxx.p_provincecode$ = 230000 THEN '黑龙江'\n    WHEN $xxx.p_provincecode$ = 310000 THEN '上海'\n    WHEN $xxx.p_provincecode$ = 320000 THEN '江苏'\n    WHEN $xxx.p_provincecode$ = 330000 THEN '浙江'\n    WHEN $xxx.p_provincecode$ = 340000 THEN '安徽'\n    WHEN $xxx.p_provincecode$ = 350000 THEN '福建'\n    WHEN $xxx.p_provincecode$ = 360000 THEN '江西'\n    WHEN $xxx.p_provincecode$ = 370000 THEN '山东'\n    WHEN $xxx.p_provincecode$ = 410000 THEN '河南'\n    WHEN $xxx.p_provincecode$ = 420000 THEN '湖北'\n    WHEN $xxx.p_provincecode$ = 430000 THEN '湖南'\n    WHEN $xxx.p_provincecode$ = 440000 THEN '广东'\n    WHEN $xxx.p_provincecode$ = 450000 THEN '广西'\n    WHEN $xxx.p_provincecode$ = 460000 THEN '海南'\n    WHEN $xxx.p_provincecode$ = 500000 THEN '重庆'\n    WHEN $xxx.p_provincecode$ = 510000 THEN '四川'\n    WHEN $xxx.p_provincecode$ = 520000 THEN '贵州'\n    WHEN $xxx.p_provincecode$ = 530000 THEN '云南'\n    WHEN $xxx.p_provincecode$ = 540000 THEN '西藏'\n    WHEN $xxx.p_provincecode$ = 610000 THEN '陕西'\n    WHEN $xxx.p_provincecode$ = 620000 THEN '甘肃'\n    WHEN $xxx.p_provincecode$ = 630000 THEN '青海'\n    WHEN $xxx.p_provincecode$ = 640000 THEN '宁夏'\n    WHEN $xxx.p_provincecode$ = 650000 THEN '新疆'\nEND", null, null, null, null, null
