theme_domain: 工参主数据
table_name: cfg_lte_cm_cel_dx_d
table_name_chinese: 4G电信工参小区汇聚结果表
data_frequency: day
primary_key: 数据描述
source_table_name[8]{源表英文名, 源表中文名, 别名, 任务描述, 备注, 是否主表}:
  itg_cm_lte_cel_d, 4G电信工参小区原始表, A, A表为主表，关联各表数据，最终生成小区维度的汇聚结果数据, 过滤条件：col_status <> 3, 是
  itg_cm_lte_ant_d, 4G电信工参天线原始表, B, null, A left join B，关联条件：A.ant_code = B.ant_code and A.p_provincecode = B.p_provincecode, null
  itg_cm_lte_enb_d, 4G电信工参基站原始表, C, null, A left join C，关联条件：A.related_enb_id = C.enb_id and A.p_provincecode = C.p_provincecode, null
  itg_cm_lte_room_d, 4G电信工参室分原始表, D, null, A left join D，关联条件：A.room_code = D.room_code and A.p_provincecode = D.p_provincecode, null
  itg_cm_lte_rru_d, 4G电信工参RRU原始表, E, null, A left join E，关联条件：A.cel_code = E.cel_object_rdn and A.p_provincecode = E.p_provincecode, null
  itg_cm_lte_sit_d, 4G电信工参站址原始表, F, null, B left join F，关联条件：B.related_sit_code = F.sit_code and B.p_provincecode = F.p_provincecode, null
  cfg_town_config_stats, 统计局省市区乡镇配置表, G, null, A left join G，关联条件：A.tjj_county_id = G.districtcode and A.p_provincecode = G.p_provincecode，回填省市区信息。注意：G表只取省市区字段，按照districtcode去重后再关联, null
  cfg_town_config_stats, 统计局省市区乡镇配置表, G1, null, A left join G1，关联条件：A.tjj_town_id = G1.towncode and A.p_provincecode = G1.p_provincecode，回填乡镇名称, null
fields[95]{PDM字段英文名, PDM字段类型, PDM字段中文名（说明）, 源表名, 源字段英文名, 算法加工逻辑, 关联与过滤条件, 备注, 字段属性, 单位, 取值范围}:
  oid, string, 小区cellkey, A, null, "concat(related_enb_id,'_',cel_id)", null, null, 维度, 无, 无
